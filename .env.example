# Vapi Configuration
VAPI_API_KEY=your_api_key_here
VAPI_PUBLIC_KEY=your_public_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here

# Optional: Webhook URL for receiving call events
VAPI_WEBHOOK_URL=https://your-domain.com/webhook/vapi

# Shared token required for all local API calls via X-DevDuck-Token
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEVDUCK_API_TOKEN=replace_with_a_strong_random_token

# Optional: Override token just for /webhook/vapi calls
# DEVDUCK_VAPI_WEBHOOK_TOKEN=replace_with_a_separate_webhook_token
